---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.tsx";
import MobileSidebar from "../components/MobileSidebar.tsx";

interface Props {
  title?: string;
  currentPath?: string;
}

const { title = "kazuki yoshida", currentPath = "/" } = Astro.props;
---

<!doctype html>
<html lang="ja" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="kazuki yoshida - ML Infra Engineer, 東京" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+JP:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen" style={`background: oklch(0.09 0.005 240);`}>
    <!-- Desktop Sidebar -->
    <div class="hidden md:block">
      <Sidebar currentPath={currentPath} client:load />
    </div>
    <!-- Mobile Header -->
    <MobileSidebar currentPath={currentPath} client:load />
    <!-- Page Content -->
    <slot />
  </body>
</html>
