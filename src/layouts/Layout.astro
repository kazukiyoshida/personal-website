---
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";
import Sidebar from "../components/Sidebar.tsx";
import MobileSidebar from "../components/MobileSidebar.tsx";

interface Props {
  title?: string;
  currentPath?: string;
}

const { title = "kazuki yoshida", currentPath = "/" } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="kazuki yoshida - ML Infra Engineer, 東京" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var theme = localStorage.getItem("theme");
        if (!theme) {
          theme = window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
        }
        document.documentElement.classList.toggle("dark", theme === "dark");
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+JP:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <ViewTransitions />
    <script is:inline>
      // Fix: Astro View Transitions ignores popstate events where
      // history.state is null (i.e. the initial page load entry).
      // This breaks the browser's swipe-back gesture on mobile because
      // the URL updates but the DOM doesn't change.
      // Force a full page load in that case.
      window.addEventListener('popstate', function(ev) {
        if (ev.state === null) {
          location.reload();
        }
      });
    </script>
  </head>
  <body class="min-h-screen">
    <!-- Desktop Sidebar -->
    <div class="hidden md:block" transition:persist>
      <Sidebar currentPath={currentPath} client:load transition:persist />
    </div>
    <!-- Mobile Header -->
    <MobileSidebar currentPath={currentPath} client:load transition:persist />
    <!-- Page Content -->
    <slot />
  </body>
</html>
